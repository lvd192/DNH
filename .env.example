# Mẫu cấu hình môi trường (.env)

# Cấu hình tài khoản gửi Email (Outlook SMTP)
SMTP_USER=user@outlook.com
SMTP_PASSWORD=YourAppPasswordOrPasswordHere
SENDER_EMAIL=user@outlook.com
RECIPIENT_EMAILS=recipient@example.com,another@example.com

# Cấu hình kết nối SQL Server (Chỉ dùng khi environment = production)
DB_HOST=127.0.0.1
DB_PORT=1433
DB_USER=sa
DB_PASS=YourStrongDbPassword
ERP_DB_NAME=ERP_Prod
CRM_DB_NAME=CRM_Prod
